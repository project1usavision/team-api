{
  "version": 2,
  "builds": [
    {
      "src": "index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/health",
      "dest": "/index.js"
    },
    {
      "src": "/api/auth/(.*)",
      "dest": "/index.js"
    },
    {
      "src": "/api/submit/(.*)",
      "dest": "/index.js"
    },
    {
      "src": "/api/admin/(.*)",
      "dest": "/index.js"
    },
    {
      "src": "/api/test-discord",
      "dest": "/index.js"
    },
    {
      "src": "/(.*)",
      "dest": "/index.js"
    }
  ]
}